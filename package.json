    "changelogen": "^0.6.2",
    "lint-staged": "^16.4.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.ts": "npm run lint"
  }
